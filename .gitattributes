# Model weights (>100 MB) MUST use Git LFS on GitHub
*.pt        filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text

# Qualitative demo/comparison audio (kept out of the git object store)
*.wav       filter=lfs diff=lfs merge=lfs -text
*.mp3       filter=lfs diff=lfs merge=lfs -text

# GitHub Pages demo site: keep its small audio as plain git blobs,
# because Pages serves LFS pointer files instead of their content
results/paper_results/single_kit_examples/audio/** -filter -diff -merge
